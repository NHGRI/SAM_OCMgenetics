#ihs_with_dhriti's_data_try2.docx
# R on computer 
setwd("Y:/HGTJAM_GSproject/HGTJAM_GSproject2/sigofsel_try1")

# dhriti's ihs data
read.table("Y:/HGTJAM_GSproject/HGTJAM_GSproject2/dhriti_OCM_iHS/benin.ihs.out") -> wgsihs
names(wgsihs) <- c("Chr", "Position", "iHS_norm")
wgsihs$dataset <- "wgs"
wgsihs[order(wgsihs$iHS_norm),] -> owgs
owgs$chrpos <- paste(owgs$Chr, owgs$Position, sep=":")
bpwgs <- data.frame("chrpos"=owgs$chrpos, "iHS_norm"=owgs$iHS_norm, "dataset"=owgs$dataset)

countries <- c("benin","botswana","cameroon","mali","nigeria","west","zambia")

for(i in countries){
read.table(paste("Y:/HGTJAM_GSproject/HGTJAM_GSproject2/dhriti_OCM_iHS/",i,".OCM.txt",sep="")) -> coun
names(coun) <- c("Chr","Gene_PositionStart","Gene_PositionEnd","Gene","Chr_a","Position1","Position2","Ignore1","Ignore2","Ignore3","iHS","iHS_norm","Ignore4")
coun$dataset <- paste(i)
coun[order(coun$iHS_norm),] -> ocoun
ocoun$chrpos <- paste(ocoun$Chr_a, ocoun$Position1, sep=":")
assign(paste(i),ocoun)
bp <- data.frame("chrpos"=ocoun$chrpos, "iHS_norm"=ocoun$iHS_norm, "dataset"=ocoun$dataset)
assign(paste("bp",i,sep=""), bp)
}

rbind(bpwgs, bpbenin, bpbotswana, bpcameroon, bpmali, bpnigeria, bpwest, bpzambia) -> dhritibp
dhritibp$dataset <- factor(dhritibp$dataset , levels=c("zambia", "west", "nigeria", "mali", "cameroon", "botswana", "benin", "wgs"))

# list of significant SNPs in prickle2
pricklesnps <- c("3:64137371","3:64146322","3:64160053","3:64161259","3:64177029","3:64177660","3:64180984")

dhritibp$pricklesnps <- ifelse(dhritibp$chrpos %in% pricklesnps == TRUE, dhritibp$iHS_norm, NA)

library(ggplot2)
library(ggtext)
library(dplyr) 

png("boxplot_dhriti_try1.png", height=800, width=1600, res=200)
ggplot(aes(x=dataset, y=iHS_norm), data=dhritibp) +
geom_boxplot(fill=c("purple", "blue", "deepskyblue", "green", "yellow", "orange", "red", "gray"), alpha=0.5)+
labs(title="Normalized iHS scores of OCM SNPs in African populations", x="Population", y="Normalized iHS")+
scale_x_discrete(labels=c("Zambia OCM SNPs", "West Africa OCM SNPs", "Nigeria OCM SNPs", "Mali OCM SNPs", "Cameroon OCM SNPs", "Botswana OCM SNPs", "Benin OCM SNPs", "Benin WGS SNPs"))+
geom_jitter(data = dhritibp %>% group_by(dataset) %>% sample_n(500),
    aes(x = dataset, y = iHS_norm),
    size = 0.3)+
geom_jitter(data=dhritibp %>% group_by(dataset), 
    aes(x=dataset, y=pricklesnps, color="magenta"),
    size=1.5)+
scale_color_identity(guide="legend", name="", labels=expression(italic(PRICKLE2)*"\n candidate SNPs"))+
theme(legend.position="bottom")+
coord_flip()
dev.off()




