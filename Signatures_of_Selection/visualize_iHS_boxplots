### JAMAICA 
# iHS data load and format 
for(i in 1:22){
read.table(paste("selscan_ihs_chr",i,"_jam_try3_ehh-win25k.ihs.out",sep="")) -> ihs
names(ihs) <- c("id", "physicalPos", "1freq", "ihh1", "ihh0","unstandardizediHS")
assign(paste("ihs",i,sep=""), ihs)
}

for(i in 1:22){
get(paste("ihs",i,sep="")) -> tempihs 
tempihs$V7 <- c(i)
colnames(tempihs)[7] <- "chr"
assign(paste("ihs",i,sep=""),tempihs)
}

rbind(ihs1,ihs2,ihs3,ihs4,ihs5,ihs6,ihs7,ihs8,ihs9,ihs10,ihs11,ihs12,ihs13,ihs14,ihs15,ihs16,ihs17,ihs18,ihs19,ihs20,ihs21,ihs22) -> allihs_try1
allihs_try1[order(allihs_try1[,6]),] -> orderedihs
row.names(orderedihs) <- NULL

# normalize iHS 
library(caret)
preproc1 <- preProcess(orderedihs[,c(1,6)], method=c("center", "scale"))
norm1 <- predict(preproc1, orderedihs[,c(1,6)])
summary(norm1)
names(norm1) <- c("id", "standardizediHS")

merge(orderedihs, norm1, by="id") -> normihs

# extract OCM SNPs 
read.table("Y:/HGTJAM_GSproject/HGTJAM_GSproject2/tomato/tomato_geno_ocmSNPs_50Kflank_allsamps_chi2.assoc", header=TRUE) -> ocmsnps 

normihs[normihs$id %in% ocmsnps$SNP,] -> ocmihs

normihs$category <- "all"
ocmihs$category <- "ocm"

rbind(normihs, ocmihs) -> myihs
myihs$category <- factor(myihs$category , levels=c("ocm", "all"))

pricklesnpss <- c("rs753562","rs17664202","rs153740","rs153737","rs161666","rs153728","kgp8116060")

myihs$pricklesnps <- ifelse(myihs$id %in% pricklesnpss == TRUE, myihs$standardizediHS, NA)

library(ggplot2)
library(ggtext)
library(dplyr) 

png("boxplot_myihs_jam_try1.png", height=800, width=1600, res=200)
ggplot(aes(x=category, y=standardizediHS), data=myihs) +
geom_boxplot(fill=c("blue", "gray"), alpha=0.5)+
labs(title="Normalized iHS scores of OCM SNPs, Jamaica", x="Category", y="Normalized iHS")+
scale_x_discrete(labels=c("OCM SNPs", "All SNPs"))+
geom_jitter(data = myihs %>% group_by(category) %>% sample_n(500),
    aes(x = category, y = standardizediHS),
    size = 0.3)+
geom_jitter(data=myihs %>% group_by(category), 
    aes(x=category, y=pricklesnps, color="magenta"),
    size=1.5)+
scale_color_identity(guide="legend", name="", labels=expression(italic(PRICKLE2)*"\n candidate SNPs"))+
theme(legend.position="bottom")+
coord_flip()
dev.off()





